generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Gender {
  MALE
  FEMALE
  OTHER
}

enum DocumentType {
  AADHAAR
  PAN
  PASSBOOK
  PROFILE
}

enum RejectionStage {
  PROFILE
  INTERVIEW
  DOCUMENT
}

enum AdminRole {
  SUPER_ADMIN
  SUB_ADMIN
  MANAGER
  SUPPORT
}

enum ServiceType {
  CATEGORY
  DIRECT_SERVICE
}

enum TransactionType {
  CREDIT
  DEBIT
}

enum WithdrawalStatus {
  PENDING
  APPROVED
  REJECTED
}

enum SessionType {
  CHAT
  CALL
}

enum SessionStatus {
  REQUESTED
  ACCEPTED
  ONGOING
  COMPLETED
  CANCELLED
  FAILED
}

enum PaymentProvider {
  RAZORPAY
  STRIPE
  CASHFREE
}

enum PaymentStatus {
  PENDING
  SUCCESS
  FAILED
}

enum PaymentOrderStatus {
  CREATED
  PAID
  FAILED
}

enum CouponType {
  PERCENTAGE
  FLAT
}

enum CouponVisibility {
  PUBLIC
  PRIVATE
}

enum PermissionType {
  SYSTEM
  CUSTOM
}

enum PricingType {
  CHAT
  CALL
  VIDEO
  AUDIO
}

// hiring astrologer process

enum InterviewStatus {
  PENDING
  SCHEDULED
  PASSED
  REJECTED
}

enum DocumentStatus {
  PENDING
  VERIFIED
  REJECTED
}

enum ApprovalStatus {
  PENDING
  APPROVED
  REJECTED
}

enum ApplicationStatus {
  PENDING
  APPROVED
  REJECTED
}

enum OfferType {
  FREE
  ONE_RUPEE
  ORIGINAL
}

model User {
  id            String         @id @default(uuid())
  name          String?
  countryCode   String?
  mobile        String?
  gender        Gender?
  birthDate     DateTime?
  birthTime     String?
  occupation    String?
  isActive      Boolean        @default(true)
  isDeleted     Boolean        @default(false)
  refreshToken  String?        @db.Text
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  intakes       Intake[]
  wallet        UserWallet?
  payments      Payment[]
  paymentOrders PaymentOrder[]
  sessions      Session[]
  reviews       Review[]

  @@unique([countryCode, mobile])
}

model Review {
  id String @id @default(uuid())

  userId String
  user   User   @relation(fields: [userId], references: [id])

  astrologerId String
  astrologer Astrologer @relation(fields: [astrologerId], references: [id], onDelete: Cascade)

  sessionId String?  @unique
  session   Session? @relation(fields: [sessionId], references: [id])

  rating  Int
  comment String?

  userName  String?
  astroName String?

  createdAt DateTime @default(now())

  @@index([userId])
  @@index([astrologerId])
}

model Intake {
  id           String   @id @default(uuid())
  userId       String
  astrologerId String
  chatId       String?
  name         String
  countryCode  String
  mobile       String
  gender       Gender?
  birthDate    DateTime
  birthTime    String
  occupation   String
  birthPlace   String
  requestType  String
  createdAt    DateTime @default(now())

  user       User       @relation(fields: [userId], references: [id])
  astrologer Astrologer @relation(fields: [astrologerId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([astrologerId])
}

model Astrologer {
  id String @id @default(uuid())

  profilePic  String?
  name        String
  dateOfBirth DateTime?
  gender      Gender
  displayName String

  refreshToken String? @db.Text

  languages String[]
  skills    String[]
  problems  String[]

  experience Int

  email     String @unique
  contactNo String

  about String

  rating Float?  @default(0)
  status Boolean @default(false)

  tags  String
  vtags String

  approvedById String?
  createdById  String?

  kycDetailId String?

  astrologerCommissionId String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  approvedBy Staff?     @relation("ApprovedAstrologers", fields: [approvedById], references: [id])
  createdBy  Staff?     @relation("CreatedAstrologers", fields: [createdById], references: [id])
  kycDetail  KycDetail?

  //kyc KycDetail? @relation(fields: [kycDetailId], references: [id])

  intakes          Intake[]
  addresses        Address[]
  experiences      ExperiencePlatform[]
  interviews       Interview[]
  documents        AstrologerDocument[]
  rejectionHistory AstrologerRejectionHistory[]
  wallet           AstrologerWallet?
  sessions         Session[]
  reviews          Review[]
  pricing          AstrologerPricing[]
  applications     AstrologerApplication[]

  @@index([rating])
  @@index([experience])
}

model AstrologerApproved {
  id         Int      @id @default(autoincrement())
  name       String
  profilePic String
  experience Int
  isActive   Boolean  @default(true)
  createdAt  DateTime @default(now())

  @@index([name])
  @@index([experience])
  @@index([isActive])
}

model Address {
  id           Int        @id @default(autoincrement())
  astrologerId String
  astrologer   Astrologer @relation(fields: [astrologerId], references: [id], onDelete: Cascade)

  street  String
  city    String
  state   String
  country String
  pincode String

  @@index([astrologerId])
  @@index([city])
  @@index([pincode])
}

model ExperiencePlatform {
  id           Int        @id @default(autoincrement())
  astrologerId String
  astrologer   Astrologer @relation(fields: [astrologerId], references: [id], onDelete: Cascade)

  platformName String
  yearsWorked  Int

  @@index([astrologerId])
  @@index([platformName])
}

model Interview {
  id           Int        @id @default(autoincrement())
  astrologerId String
  astrologer   Astrologer @relation(fields: [astrologerId], references: [id], onDelete: Cascade)

  roundNumber     Int
  interviewerName String
  scheduledAt     DateTime
  status          InterviewStatus @default(SCHEDULED)
  remarks         String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([astrologerId, roundNumber])
  @@index([astrologerId])
  @@index([scheduledAt])
  @@index([status])
}

model AstrologerDocument {
  id           Int        @id @default(autoincrement())
  astrologerId String
  astrologer   Astrologer @relation(fields: [astrologerId], references: [id], onDelete: Cascade)

  documentType DocumentType
  documentUrl  String
  status       DocumentStatus @default(PENDING)
  verifiedBy   String?
  verifiedAt   DateTime?
  remarks      String?

  createdAt DateTime @default(now())

  @@unique([astrologerId, documentType])
  @@index([astrologerId])
  @@index([status])
}

model AstrologerRejectionHistory {
  id           Int        @id @default(autoincrement())
  astrologerId String
  astrologer   Astrologer @relation(fields: [astrologerId], references: [id], onDelete: Cascade)

  stage      RejectionStage
  reason     String
  rejectedBy String

  createdAt DateTime @default(now())

  @@index([astrologerId])
  @@index([stage])
}

model Admin {
  id           String   @id @default(uuid())
  name         String
  email        String   @unique
  phoneNo      String   @unique
  department   String?
  roleId       String
  password     String?
  isActive     Boolean  @default(true)
  isDeleted    Boolean  @default(false)
  refreshToken String?  @db.Text
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  role         Role     @relation(fields: [roleId], references: [id])

  @@index([roleId])
  @@index([isActive])
  @@index([isDeleted])
}

model Role {
  id          String           @id @default(uuid())
  name        String           @unique
  slug        String           @unique
  description String?
  isActive    Boolean          @default(true)
  isDeleted   Boolean          @default(false)
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt
  admins      Admin[]
  permissions RolePermission[]
  staff       Staff[]

  @@index([name])
  @@index([slug])
}

model Permission {
  id               String             @id @default(uuid())
  name             String             @unique
  description      String?
  type             PermissionType     @default(SYSTEM)
  createdAt        DateTime           @default(now())
  updatedAt        DateTime           @updatedAt
  isDeleted        Boolean            @default(false)
  modules          ModulePermission[]
  roles            RolePermission[]
  staffPermissions StaffPermission[]

  @@index([name])
  @@index([type])
}

model ModulePermission {
  id           String     @id @default(uuid())
  moduleId     String
  permissionId String
  module       Module     @relation(fields: [moduleId], references: [id], onDelete: Cascade)
  permission   Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  @@unique([moduleId, permissionId])
}

model Module {
  id          String             @id @default(uuid())
  name        String             @unique
  slug        String             @unique
  description String?
  isActive    Boolean            @default(true)
  section     String
  createdAt   DateTime           @default(now())
  updatedAt   DateTime           @updatedAt
  isDeleted   Boolean            @default(false)
  permissions ModulePermission[]

  @@index([name])
  @@index([slug])
}

model Department {
  id           String   @id @default(uuid())
  name         String   @unique
  slug         String   @unique
  description  String?
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  isDeleted    Boolean  @default(false)
  staffMembers Staff[]
}

model Staff {
  id                  String                  @id @default(uuid())
  name                String
  email               String                  @unique
  password            String
  roleId              String
  departmentId        String
  isActive            Boolean                 @default(true)
  isDeleted           Boolean                 @default(false)
  createdAt           DateTime                @default(now())
  updatedAt           DateTime                @updatedAt
  approvedAstrologers Astrologer[]            @relation("ApprovedAstrologers")
  createdAstrologers  Astrologer[]            @relation("CreatedAstrologers")
  department          Department              @relation(fields: [departmentId], references: [id], onDelete: Cascade)
  role                Role                    @relation(fields: [roleId], references: [id])
  permissions         StaffPermission[]
  //  INTERVIEWER SIDE
  interviews          AstrologerApplication[] @relation("InterviewerRelation")

  createdApplications AstrologerApplication[] @relation("StaffRelation")
  Notification        Notification[]

  @@index([roleId])
  @@index([departmentId])
}

model StaffPermission {
  id           String     @id @default(uuid())
  staffId      String
  permissionId String
  permission   Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)
  staff        Staff      @relation(fields: [staffId], references: [id], onDelete: Cascade)

  @@unique([staffId, permissionId])
}

model Category {
  id        String    @id @default(cuid())
  name      String    @unique
  slug      String    @unique
  createdAt DateTime  @default(now())
  services  Service[]
}

model Service {
  id          String      @id @default(cuid())
  name        String
  slug        String      @unique
  type        ServiceType
  categoryId  String?
  image       String?
  description String?
  longText    String?
  price       Float?
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt
  category    Category?   @relation(fields: [categoryId], references: [id])
}

model Gift {
  id        String   @id @default(cuid())
  name      String
  amount    Float
  image     String?
  status    String   @default("active")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Testimonial {
  id        String   @id @default(uuid())
  name      String
  address   String?
  content   String
  image     String?
  rating    Int
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Faq {
  id        String   @id @default(uuid())
  question  String
  answer    String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Banner {
  id         String   @id @default(uuid())
  heading    String
  subheading String
  slug       String   @unique
  sortorder  Int
  bannerlink String
  language   String   @default("en")
  imageUrl   String
  status     Boolean  @default(true)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
}

model RolePermission {
  id String @id @default(uuid())

  roleId       String
  permissionId String

  role       Role       @relation(fields: [roleId], references: [id], onDelete: Cascade)
  permission Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@unique([roleId, permissionId])
  @@index([roleId])
  @@index([permissionId])
}

model RechargePack {
  id            String              @id @default(uuid())
  name          String
  description   String?
  price         Float
  coins         Int
  talktime      Int
  validityDays  Int
  isActive      Boolean             @default(true)
  createdAt     DateTime            @default(now())
  updatedAt     DateTime            @updatedAt
  payments      Payment[]
  paymentOrders PaymentOrder[]
  transactions  WalletTransaction[]
  coupons       Coupon[]            @relation("CouponToRechargePack")

  @@index([isActive])
  @@index([price])
  @@index([coins])
  @@index([createdAt])
}

model UserWallet {
  id     String @id @default(uuid())
  userId String @unique
  user   User   @relation(fields: [userId], references: [id])

  balanceCoins Float @default(0)
  lockedCoins  Float @default(0)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  transactions WalletTransaction[]
}

model AstrologerWallet {
  id             String       @id @default(uuid())
  astrologerId   String       @unique
  astrologer   Astrologer @relation(fields: [astrologerId], references: [id], onDelete: Cascade)
  balanceCoins   Float        @default(0)
  totalEarned    Int          @default(0)
  totalWithdrawn Int          @default(0)
  withdrawals    Withdrawal[]
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
  transactions WalletTransaction[]

  @@index([astrologerId])
}

model WalletTransaction {
  id String @id @default(uuid())

  userWalletId String?
  userWallet   UserWallet? @relation(fields: [userWalletId], references: [id])

  astrologerWalletId String?
  astrologerWallet   AstrologerWallet? @relation(fields: [astrologerWalletId], references: [id])

  rechargePackId String?
  rechargePack   RechargePack? @relation(fields: [rechargePackId], references: [id])

  sessionId String?
  session   Session? @relation(fields: [sessionId], references: [id])

  //  ADD THIS (CRITICAL)
  paymentId String?
  payment   Payment? @relation(fields: [paymentId], references: [id])

  type        TransactionType
  coins       Int
  amount      Float?
  description String?

  createdAt DateTime @default(now())

  //  PREVENT duplicate credit from same payment
  @@unique([paymentId, type])
  @@index([userWalletId])
  @@index([astrologerWalletId])
  @@index([sessionId])
  @@index([paymentId])
  @@index([createdAt])
}

model Withdrawal {
  id String @id @default(uuid())

  astrologerWalletId String
  astrologerWallet   AstrologerWallet @relation(fields: [astrologerWalletId], references: [id])

  amount Float
  coins  Int

  status WithdrawalStatus

  requestedAt DateTime  @default(now())
  processedAt DateTime?

  transactionRef String?

  @@index([astrologerWalletId])
  @@index([status])
}

model Session {
  id String @id @default(uuid())

  userId String
  user   User   @relation(fields: [userId], references: [id])

  astrologerId String
 astrologer Astrologer @relation(fields: [astrologerId], references: [id], onDelete: Cascade)

  type   SessionType
  status SessionStatus

  ratePerMin  Int
  durationSec Int @default(0)

  coinsDeducted Int                 @default(0)
  coinsEarned   Int                 @default(0)
  commission    Int                 @default(0)
  review        Review?
  startedAt     DateTime?
  endedAt       DateTime?
  messages      Message[]
  createdAt     DateTime            @default(now())
  transactions  WalletTransaction[]
  fraudLogs FraudLog[] 
  @@index([userId])
  @@index([astrologerId])
  @@index([status])
  @@index([createdAt])
}

model Payment {
  id String @id @default(uuid())

  userId String
  user   User   @relation(fields: [userId], references: [id])

  rechargePackId String
  rechargePack   RechargePack @relation(fields: [rechargePackId], references: [id])

  paymentOrderId String       @unique
  paymentOrder   PaymentOrder @relation(fields: [paymentOrderId], references: [id])

  amount Float
  coins  Int

  provider PaymentProvider

  razorpayOrderId   String
  razorpayPaymentId String @unique

  status PaymentStatus

  createdAt DateTime @default(now())

  // ADD THIS
  walletTransactions WalletTransaction[]

  @@index([userId])
  @@index([status])
  @@index([razorpayOrderId])
}

model PaymentOrder {
  id String @id @default(uuid())

  userId String
  user   User   @relation(fields: [userId], references: [id])

  rechargePackId String
  rechargePack   RechargePack @relation(fields: [rechargePackId], references: [id])

  razorpayOrderId String @unique

  amount Float
  coins  Int

  status PaymentOrderStatus @default(CREATED)

  payment Payment?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
  @@index([razorpayOrderId])
  @@index([status])
}

model Coupon {
  id             String           @id @default(uuid())
  code           String           @unique
  description    String?
  type           CouponType
  visibility     CouponVisibility
  status         Boolean          @default(true)
  percentage     Float?
  flatAmount     Float?
  maxDiscount    Float?
  minOrderAmount Float?
  redeemLimit    Int?
  usedCount      Int              @default(0)
  startDate      DateTime
  endDate        DateTime
  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @updatedAt
  rechargePacks  RechargePack[]   @relation("CouponToRechargePack")
}

model Message {
  id String @id @default(uuid())

  msgId  String
  roomId String

  senderId   String
  receiverId String?

  message String
  image   String?
  sender  String

  replyTo Json?

  sessionId String?
  session   Session? @relation(fields: [sessionId], references: [id])

  createdAt DateTime @default(now())

  @@index([roomId])
  @@index([sessionId])
  @@index([senderId])
}

model AstrologerApplication {
  id          String   @id @default(uuid())
  name        String
  phoneNumber String   @unique
  email       String?  @unique
  dob         DateTime
  gender      Gender
  languages   String[]
  problems    String[]

  skills               String[]
  experience           Int
  about                String?
  address              String
  pincode              String?
  applicationStatus    ApplicationStatus @default(PENDING)
  interviewStatus      InterviewStatus   @default(PENDING)
  documentStatus       DocumentStatus    @default(PENDING)
  approvalStatus       ApprovalStatus    @default(PENDING)
  interviewerId        String?
  interviewer          Staff?            @relation("InterviewerRelation", fields: [interviewerId], references: [id])
  interviewDate        DateTime?
  interviewTime        String?
  round                Int?
  interviewRemarks     String?
  interviewTakenAt     DateTime?
  interviewScheduledAt DateTime?
  staffId              String?
  staff                Staff?            @relation("StaffRelation", fields: [staffId], references: [id])
  createdAt            DateTime          @default(now())
  updatedAt            DateTime          @updatedAt
  astrologerId         String?
  astrologer           Astrologer?       @relation(fields: [astrologerId], references: [id])

  kycDetail KycDetail?

  @@index([applicationStatus])
  @@index([interviewStatus])
  @@index([approvalStatus])
}

model KycDetail {
  id String @id @default(uuid())

  astrologerApplicationId String?                @unique
  application             AstrologerApplication? @relation(fields: [astrologerApplicationId], references: [id])

  accountHolderName String?
  accountNumber     String?
  bankName          String?
  ifsc              String?
  branchName        String?
  panNumber         String?

  profileImage  String?
  aadhaarImage  String?
  panImage      String?
  passbookImage String?

  status DocumentStatus @default(PENDING)

  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt
  astrologerId String?     @unique
  astrologer   Astrologer? @relation(fields: [astrologerId], references: [id])
}

model Notification {
  id String @id @default(uuid())

  staffId String
  staff   Staff  @relation(fields: [staffId], references: [id])

  message String
  isRead  Boolean @default(false)

  createdAt DateTime @default(now())
}

model PricingConfig {
  id String @id @default(uuid())

  isFirstOfferEnabled Boolean @default(true)
  firstChatPrice      Int     @default(0)
  firstCallPrice      Int     @default(0)

  isSecondOfferEnabled Boolean @default(false)
  secondChatPrice      Int     @default(0)
  secondCallPrice      Int     @default(0)
}

model UserOfferUsage {
  id     String @id @default(uuid())
  userId String @unique

  visitCount Int @default(0)

  usedFirst  Boolean @default(false)
  usedSecond Boolean @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model AstrologerPricing {
  id                String      @id @default(uuid())
  astrologerId      String
  type              PricingType
  price             Float
  offerPrice        Float?
  commissionPercent Float?
  isActive          Boolean     @default(true)

 astrologer Astrologer @relation(fields: [astrologerId], references: [id], onDelete: Cascade)

  @@unique([astrologerId, type])
}

model FraudFlag {
  id String @id @default(uuid())

  keyword String @unique

  createdBy String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([keyword])
}
enum FraudStatus {
  PENDING
  FRAUD
  FINE
}

model FraudLog {
  id String @id @default(uuid())

  orderId String?

  sessionId String?
  session   Session? @relation(fields: [sessionId], references: [id])

  senderId String?
  senderName String?

  receiverId String?
  receiverName String?

  message String @db.Text

  matchedKeywords String[]

  status FraudStatus @default(PENDING)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([sessionId])
  @@index([senderId])
  @@index([receiverId])
  @@index([status])
  @@index([createdAt])
}
